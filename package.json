{
  "name": "wordflare",
  "version": "0.0.0",
  "private": true,
  "description": "A reusable, single-tenant blog engine on Cloudflare's native stack.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply wordflare --local",
    "db:migrate:remote": "wrangler d1 migrations apply wordflare --remote"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.71",
    "@cloudflare/workers-types": "^5.20260719.1",
    "typescript": "^7.0.2",
    "vitest": "^3.2.7",
    "wrangler": "^4.112.0"
  }
}
